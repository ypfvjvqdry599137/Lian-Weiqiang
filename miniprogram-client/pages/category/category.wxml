<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-item" bindtap="goToPage" data-url="/pages/index/index">首页</view>
    <view class="nav-item active">分类</view>
    <view class="nav-item" bindtap="goToPage" data-url="/pages/cart/cart">购物车</view>
    <view class="nav-item" bindtap="goToPage" data-url="/pages/orders/orders">订单</view>
  </view>
  
  <view class="category-wrapper">
    <!-- 左侧分类导航 -->
    <scroll-view class="category-nav" scroll-y="true">
      <view 
        class="nav-item {{index === currentCategory ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="selectCategory"
        data-index="{{index}}"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <!-- 右侧商品列表 -->
    <scroll-view class="product-wrapper" scroll-y="true">
      <view class="product-card" wx:for="{{products}}" wx:key="id">
        <image src="{{item.image_url || '/images/placeholder.png'}}" class="product-img" />
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="price">¥{{item.price}}/{{item.unit}}</view>
          <view class="add-btn" bindtap="addToCart" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

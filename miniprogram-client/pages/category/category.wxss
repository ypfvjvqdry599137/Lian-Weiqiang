.container {
  height: 100vh;
}

.category-wrapper {
  display: flex;
  height: 100%;
}

.category-nav {
  width: 180rpx;
  background: #f5f5f5;
  height: 100%;
}

.nav-item {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  border-left: 6rpx solid transparent;
}

.nav-item.active {
  background: white;
  color: #4CAF50;
  border-left-color: #4CAF50;
  font-weight: bold;
}

.product-wrapper {
  flex: 1;
  background: white;
  padding: 20rpx;
}

.product-card {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
}

.price {
  font-size: 32rpx;
  color: #e64340;
  font-weight: bold;
}

.add-btn {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 60rpx;
  height: 60rpx;
  background: #4CAF50;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

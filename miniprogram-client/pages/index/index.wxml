<view class="container">
  <!-- 顶部搜索栏和自提点 -->
  <view class="header">
    <view class="station">
      <text class="station-name">{{stationName}}</text>
      <text class="station-address">{{stationAddress}}</text>
    </view>
    <view class="search">
      <input type="text" placeholder="搜索商品" class="search-input" />
    </view>
  </view>

  <!-- 推荐商品横幅 -->
  <view class="recommend-banner" wx:if="{{recommendProducts.length > 0}}">
    <text class="banner-title">🔥 今日推荐</text>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="product-image">
        <image src="{{item.image_url || '/images/placeholder.png'}}" mode="aspectFill" class="product-img" />
      </view>
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-desc">{{item.description || '新鲜直达'}}</view>
        <view class="product-bottom">
          <view class="price-section">
            <text class="price">¥{{item.price}}</text>
            <text class="price-original" wx:if="{{item.original_price}}">¥{{item.original_price}}</text>
          </view>
          <text class="unit">/ {{item.unit}}</text>
        </view>
        <view class="add-btn" bindtap="addToCart" data-id="{{item.id}}" catchtap="true">
          <text>+ 加入购物车</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{products.length === 0 && !loading}}">
    <text>暂无商品</text>
  </view>
</view>

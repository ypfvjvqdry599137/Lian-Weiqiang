.container {
  padding-bottom: 120rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.header {
  padding: 20rpx;
  background: linear-gradient(180deg, #4CAF50 0%, #45a049 100%);
  color: white;
}

.address {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255,255,255,0.2);
  padding: 16rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 16rpx;
}

.address-icon {
  font-size: 32rpx;
}

.address-text {
  flex: 1;
}

.address-name {
  font-size: 26rpx;
  font-weight: bold;
  display: block;
  line-height: 1.2;
}

.address-detail {
  font-size: 20rpx;
  opacity: 0.9;
  display: block;
  line-height: 1.2;
}

.arrow {
  font-size: 20rpx;
  opacity: 0.8;
}

.search {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 320rpx;
  margin-bottom: 20rpx;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-1 {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.banner-2 {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
}

.banner-3 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.banner-text {
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 快捷分类 */
.quick-nav {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 20rpx 30rpx;
  background: white;
  margin-bottom: 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.nav-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.nav-name {
  font-size: 24rpx;
  color: #333;
}

/* 通用区域样式 */
.section {
  padding: 20rpx;
  background: white;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.title-icon {
  font-size: 32rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.more {
  font-size: 24rpx;
  color: #999;
}

/* 限时特惠 */
.flash-list {
  display: flex;
  white-space: nowrap;
}

.flash-item {
  display: inline-block;
  width: 220rpx;
  margin-right: 16rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  overflow: hidden;
}

.flash-img {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8f5e9 100%);
}

.flash-img .img {
  width: 100%;
  height: 100%;
}

.flash-info {
  padding: 16rpx;
}

.flash-name {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flash-price {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.flash-price .price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF5722;
}

.flash-price .unit {
  font-size: 22rpx;
  color: #666;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.product-card {
  width: calc(50% - 8rpx);
  background: #f9f9f9;
  border-radius: 16rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8f5e9 100%);
}

.product-img {
  width: 100%;
  height: 100%;
}

.img-placeholder,
.product-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4CAF50;
  font-size: 64rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.product-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-box {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.price-box .price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF5722;
}

.price-box .unit {
  font-size: 22rpx;
  color: #666;
}

.add-btn {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(76, 175, 80, 0.3);
}

.add-icon {
  font-size: 32rpx;
  color: white;
  line-height: 1;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 自提点选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}

.picker-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 1000;
  max-height: 70vh;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.15);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel,
.picker-confirm {
  font-size: 30rpx;
  color: #666;
  padding: 10rpx;
}

.picker-confirm {
  color: #4CAF50;
  font-weight: bold;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-list {
  padding: 20rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #f5f7fa;
  transition: all 0.3s;
}

.picker-item.active {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 2rpx solid #4CAF50;
}

.station-item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.station-item-address {
  font-size: 26rpx;
  color: #666;
}

/* 底部导航栏 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  padding: 15rpx 0;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 1000;
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #666;
  transition: all 0.3s;
}

.bottom-nav-item.active {
  color: #4CAF50;
}

.bottom-nav-item .nav-icon {
  font-size: 40rpx;
  line-height: 1;
}

.bottom-nav-item .nav-text {
  font-size: 22rpx;
  line-height: 1;
}

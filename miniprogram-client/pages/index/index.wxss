.container {
  padding-bottom: 40rpx;
}

.header {
  padding: 20rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
}

.station {
  margin-bottom: 20rpx;
}

.station-name {
  font-size: 36rpx;
  font-weight: bold;
}

.station-address {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 10rpx;
  display: block;
}

.search {
  background: white;
  border-radius: 50rpx;
  padding: 15rpx 30rpx;
}

.search-input {
  font-size: 28rpx;
}

.recommend-banner {
  margin: 20rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 16rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #E65100;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-info {
  padding: 20rpx;
  position: relative;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.product-bottom {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
}

.price-section {
  display: flex;
  align-items: flex-end;
  flex: 1;
}

.unit {
  font-size: 24rpx;
  color: #666;
}

.add-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background: #4CAF50;
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

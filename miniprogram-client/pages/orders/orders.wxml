<view class="container">
  <view class="tabs">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待处理</view>
    <view class="tab-item {{currentTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
    <view class="tab-item {{currentTab === 'canceled' ? 'active' : ''}}" bindtap="switchTab" data-tab="canceled">已取消</view>
  </view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="order_sn" bindtap="goToDetail" data-id="{{item.order_sn}}">
      <view class="order-header">
        <text class="order-sn">订单号：{{item.order_sn}}</text>
        <text class="order-status status-{{item.order_status}}">{{item.status_text}}</text>
      </view>

      <view class="order-content">
        <view class="product-mini" wx:for="{{item.items}}" wx:key="product_name" wx:for-item="product">
          <view class="product-name">{{product.product_name}}</view>
          <view class="product-qty">x{{product.quantity}}</view>
        </view>
      </view>

      <view class="order-footer">
        <text class="order-time">{{item.created_at}}</text>
        <text class="order-price">合计：¥{{item.final_amount || item.total_amount}}</text>
      </view>

      <view class="order-actions" wx:if="{{item.can_cancel}}">
        <button class="cancel-btn" catchtap="cancelOrder" data-sn="{{item.order_sn}}">取消订单</button>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{orders.length === 0}}">
    <text>暂无订单</text>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav-item" bindtap="goToIndex">
      <text class="nav-icon">🏠</text>
      <text class="nav-text">首页</text>
    </view>
    <view class="bottom-nav-item" bindtap="goToCategory">
      <text class="nav-icon">📦</text>
      <text class="nav-text">分类</text>
    </view>
    <view class="bottom-nav-item" bindtap="goToCart">
      <text class="nav-icon">🛒</text>
      <text class="nav-text">购物车</text>
    </view>
    <view class="bottom-nav-item active">
      <text class="nav-icon">👤</text>
      <text class="nav-text">我的</text>
    </view>
  </view>
</view>

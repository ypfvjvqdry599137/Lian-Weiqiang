.container {
  padding-bottom: 160rpx;
}

.tabs {
  display: flex;
  background: white;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4CAF50;
  border-radius: 2rpx;
}

.order-card {
  background: white;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-sn {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: bold;
}

.status-10,
.status-20 {
  color: #f59e0b;
}

.status-30,
.status-40 {
  color: #2563eb;
}

.status-50 {
  color: #4CAF50;
}

.status-60 {
  color: #999;
}

.order-content {
  margin-bottom: 20rpx;
}

.product-mini {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 28rpx;
}

.product-name {
  color: #333;
}

.product-qty {
  color: #666;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
}

.cancel-btn {
  width: 170rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid #e64340;
  border-radius: 30rpx;
  background: #fff;
  color: #e64340;
  font-size: 26rpx;
}

.cancel-btn::after {
  border: none;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  padding: 15rpx 0;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 1000;
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #999;
  font-size: 22rpx;
}

.bottom-nav-item.active {
  color: #4CAF50;
}

.nav-icon {
  font-size: 44rpx;
  line-height: 1;
}

<view class="container" wx:if="{{order}}">
  <view class="nav-bar">
    <view class="nav-item back-btn" bindtap="goBack">返回</view>
    <view class="nav-title">订单详情</view>
  </view>

  <view class="status-section status-bg-{{order.order_status}}">
    <view class="status-text">{{order.status_text}}</view>
    <view class="status-desc">
      <block wx:if="{{order.can_cancel}}">如需调整订单，可在商家配货前取消</block>
      <block wx:else>订单状态已更新</block>
    </view>
  </view>

  <view class="card">
    <view class="info-row">
      <text class="label">订单号</text>
      <text class="value">{{order.order_sn}}</text>
    </view>
    <view class="info-row">
      <text class="label">下单时间</text>
      <text class="value">{{order.created_at}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">配送信息</view>
    <view class="info-row">
      <text class="label">收货人</text>
      <text class="value">{{order.receiver_name}} {{order.receiver_phone}}</text>
    </view>
    <view class="info-row address-row">
      <text class="label">地址</text>
      <text class="value address-value">{{order.receiver_address}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="label">备注</text>
      <text class="value">{{order.remark}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">商品清单</view>
    <view class="product-item" wx:for="{{order.items}}" wx:key="product_name">
      <image wx:if="{{item.product_image}}" src="{{item.product_image}}" class="product-img" mode="aspectFill" />
      <view wx:else class="product-placeholder">鲜</view>
      <view class="product-info">
        <view class="product-name">{{item.product_name}}</view>
        <view class="product-meta">
          <text class="price">¥{{item.price}}</text>
          <text class="quantity">x {{item.quantity}}{{item.unit}}</text>
        </view>
      </view>
    </view>

    <view class="amount-row">
      <text>商品金额</text>
      <text>¥{{order.total_amount}}</text>
    </view>
    <view class="amount-row">
      <text>配送费</text>
      <text>¥{{order.delivery_fee}}</text>
    </view>
    <view class="total-row">
      <text>合计</text>
      <text class="total-price">¥{{order.final_amount || order.total_amount}}</text>
    </view>
  </view>

  <view class="detail-actions" wx:if="{{order.can_cancel}}">
    <button class="cancel-order-btn" bindtap="cancelOrder">取消订单</button>
  </view>
</view>

<view class="empty" wx:else>
  <text>订单加载中...</text>
</view>

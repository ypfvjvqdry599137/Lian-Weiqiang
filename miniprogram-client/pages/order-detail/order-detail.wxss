.container {
  padding-bottom: 150rpx;
}

.nav-bar {
  display: flex;
  background: white;
  padding: 20rpx;
  justify-content: flex-start;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.nav-item {
  padding: 15rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 30rpx;
}

.back-btn {
  font-size: 28rpx;
  padding: 14rpx 24rpx;
  background: #f5f5f5;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}

.status-section {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 60rpx 40rpx;
  color: white;
}

.status-bg-10,
.status-bg-20 {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.status-bg-30,
.status-bg-40 {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
}

.status-bg-50 {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
}

.status-bg-60 {
  background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.status-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.card {
  background: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.address-row {
  align-items: flex-start;
}

.address-value {
  flex: 1;
  margin-left: 24rpx;
  line-height: 1.5;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
}

.product-placeholder {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 12rpx;
  background: #edf7ef;
  color: #4CAF50;
  font-size: 42rpx;
  font-weight: bold;
  text-align: center;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
}

.price {
  color: #e64340;
  font-size: 32rpx;
  font-weight: bold;
}

.quantity {
  font-size: 26rpx;
  color: #666;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 28rpx;
  color: #666;
}

.total-row {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e64340;
}

.detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 30rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.cancel-order-btn {
  height: 82rpx;
  line-height: 82rpx;
  border: 1rpx solid #e64340;
  border-radius: 42rpx;
  background: #fff;
  color: #e64340;
  font-size: 30rpx;
}

.cancel-order-btn::after {
  border: none;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

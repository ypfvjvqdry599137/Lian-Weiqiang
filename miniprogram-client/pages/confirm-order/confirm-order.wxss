.container {
  padding-bottom: 200rpx;
  background: #f5f5f5;
}

/* 收货地址 */
.address-card {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-info {
  flex: 1;
}

.addr-name-phone {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.addr-phone {
  font-size: 26rpx;
  color: #666;
}

.addr-detail {
  font-size: 26rpx;
  color: #666;
}

.address-placeholder {
  flex: 1;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
}

.arrow {
  font-size: 28rpx;
  color: #999;
}

.section {
  background: white;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 配送信息 */
.delivery-info {
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
}

.delivery-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.delivery-item .label {
  color: #666;
}

.delivery-item .value {
  color: #333;
}

.delivery-item .value.price {
  color: #ff5722;
  font-weight: bold;
}

.range-tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
}

.tip-icon {
  font-size: 26rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #ff9800;
}

/* 商品 */
.product-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-item:last-child {
  border-bottom: none;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
}

.product-detail {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  color: #e64340;
  font-size: 32rpx;
  font-weight: bold;
}

.quantity {
  font-size: 26rpx;
  color: #666;
}

.textarea {
  width: 100%;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  min-height: 150rpx;
  font-size: 28rpx;
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.total {
  flex: 1;
}

.total-row {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
  font-size: 26rpx;
  color: #666;
}

.total-row.final {
  padding-top: 10rpx;
  border-top: 1rpx solid #eee;
  margin-top: 8rpx;
}

.total-price {
  color: #333;
  font-weight: 500;
}

.final-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e64340;
}

.submit-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #999;
}

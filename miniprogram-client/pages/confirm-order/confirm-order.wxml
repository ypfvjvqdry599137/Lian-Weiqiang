<view class="container">
  <!-- 收货地址 -->
  <view class="address-card" bindtap="goToSelectAddress">
    <view class="address-info" wx:if="{{selectedAddress}}">
      <view class="addr-name-phone">
        <text class="addr-name">{{selectedAddress.receiver_name}}</text>
        <text class="addr-phone">{{selectedAddress.receiver_phone}}</text>
      </view>
      <view class="addr-detail">{{selectedAddress.address}}</view>
    </view>
    <view class="address-placeholder" wx:else>
      <text class="placeholder-text">请选择收货地址</text>
    </view>
    <text class="arrow">></text>
  </view>

  <!-- 配送信息 -->
  <view class="section" wx:if="{{selectedAddress}}">
    <view class="delivery-info">
      <view class="delivery-item">
        <text class="label">配送区域</text>
        <text class="value" wx:if="{{deliveryZone}}">{{deliveryZone.zone_name}}</text>
        <text class="value" wx:else>正在计算...</text>
      </view>
      <view class="delivery-item">
        <text class="label">配送费</text>
        <text class="value price" wx:if="{{deliveryZone}}">¥{{deliveryZone.delivery_fee}}</text>
        <text class="value" wx:else>--</text>
      </view>
      <view class="delivery-item">
        <text class="label">预计送达</text>
        <text class="value" wx:if="{{deliveryZone}}">{{deliveryZone.delivery_time}}</text>
        <text class="value" wx:else>--</text>
      </view>
    </view>
    <!-- 配送范围提示 -->
    <view class="range-tip" wx:if="{{!inRange && selectedAddress && deliveryZone}}">
      <text class="tip-icon">⚠️</text>
      <text class="tip-text">当前地址不在配送范围内，请更换地址</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section">
    <view class="section-title">商品清单</view>
    <view class="product-item" wx:for="{{products}}" wx:key="product_id">
      <image src="{{item.product_image || ''}}" class="product-img" />
      <view class="product-detail">
        <view class="product-name">{{item.product_name}}</view>
        <view class="product-meta">
          <text class="price">¥{{item.price}}</text>
          <text class="quantity">× {{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section">
    <view class="section-title">备注</view>
    <textarea class="textarea" placeholder="选填，可以填写特殊要求..." bindinput="onRemarkInput" />
  </view>

  <!-- 底部 -->
  <view class="footer">
    <view class="total">
      <view class="total-row">
        <text>商品合计：</text>
        <text class="total-price">¥{{totalPrice}}</text>
      </view>
      <view class="total-row">
        <text>配送费：</text>
        <text class="price" wx:if="{{deliveryZone}}">¥{{deliveryZone.delivery_fee}}</text>
        <text wx:else>¥0.00</text>
      </view>
      <view class="total-row final">
        <text>实付：</text>
        <text class="final-price">¥{{finalPrice}}</text>
      </view>
    </view>
    <button class="submit-btn" bindtap="submitOrder" disabled="{{!selectedAddress || !inRange || !deliveryZone}}">
      {{!selectedAddress ? '请先选择地址' : (!inRange ? '不在配送范围' : '提交订单')}}
    </button>
  </view>
</view>

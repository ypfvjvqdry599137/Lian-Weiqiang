.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 地址列表样式 */
.add-btn {
  margin: 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  color: #4CAF50;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.add-btn .icon {
  font-size: 40rpx;
  font-weight: bold;
}

.address-items {
  padding: 0 30rpx;
}

.address-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.address-item.selected {
  border: 3rpx solid #4CAF50;
}

.address-info {
  flex: 1;
}

.name-phone {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.name-phone .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.name-phone .phone {
  font-size: 28rpx;
  color: #666;
}

.default-tag {
  background: #E8F5E9;
  color: #4CAF50;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.address-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.address-actions {
  display: flex;
  gap: 30rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  font-size: 26rpx;
  color: #666;
}

.action-btn.delete {
  color: #f44336;
}

.selected-icon {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  font-size: 36rpx;
  color: #4CAF50;
}

/* 地址表单样式 */
.address-form {
  background: #fff;
  min-height: 100vh;
}

.form-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  gap: 20rpx;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
}

.form-title {
  font-size: 34rpx;
  font-weight: 600;
}

.form-group {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  font-size: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 10rpx;
}

.location-picker {
  width: 100%;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 2rpx dashed #4CAF50;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.location-text {
  flex: 1;
  font-size: 30rpx;
  color: #4CAF50;
  font-weight: 500;
}

.location-text:empty {
  color: #666;
  font-weight: normal;
}

.location-icon {
  font-size: 48rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(76,175,80,0.2));
}

.default-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-btn {
  width: 100rpx;
  height: 56rpx;
  background: #ddd;
  border-radius: 50rpx;
  position: relative;
  transition: all 0.3s;
}

.switch-btn.active {
  background: #4CAF50;
}

.switch-dot {
  position: absolute;
  right: 4rpx;
  top: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.save-btn {
  margin: 60rpx 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
}

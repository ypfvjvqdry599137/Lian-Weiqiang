<view class="container">
  <!-- 地址列表 -->
  <view wx:if="{{mode === 'list'}}" class="address-list">
    <!-- 添加按钮 -->
    <view class="add-btn" bindtap="goToAdd">
      <text class="icon">+</text>
      <text>新增收货地址</text>
    </view>

    <!-- 地址列表 -->
    <view class="address-items">
      <view 
        wx:for="{{addresses}}" 
        wx:key="id"
        class="address-item {{selectedAddressId === item.id ? 'selected' : ''}}"
        data-address="{{item}}"
        bindtap="selectAddress"
      >
        <view class="address-info" data-address="{{item}}" bindtap="selectAddress">
          <view class="name-phone">
            <text class="name">{{item.receiver_name}}</text>
            <text class="phone">{{item.receiver_phone}}</text>
            <text wx:if="{{item.is_default}}" class="default-tag">默认</text>
          </view>
          <view class="address-text">{{item.address}}</view>
        </view>
        <view class="address-actions">
          <view class="action-btn" data-id="{{item.id}}" bindtap="setDefault">设为默认</view>
          <view class="action-btn" data-address="{{item}}" bindtap="goToEdit">编辑</view>
          <view class="action-btn delete" data-id="{{item.id}}" bindtap="deleteAddress">删除</view>
        </view>
        <view wx:if="{{selectedAddressId === item.id}}" class="selected-icon">✓</view>
      </view>
    </view>
  </view>

  <!-- 添加/编辑地址 -->
  <view wx:if="{{mode === 'add' || mode === 'edit'}}" class="address-form">
    <view class="form-header">
      <view class="back-btn" bindtap="goBack">← 返回</view>
      <text class="form-title">{{mode === 'add' ? '新增地址' : '编辑地址'}}</text>
    </view>
    
    <view class="form-group">
      <view class="form-label">收货人</view>
      <input 
        class="form-input" 
        placeholder="请输入收货人姓名" 
        value="{{form.receiver_name}}"
        data-field="receiver_name"
        bindinput="onInput"
      />
    </view>
    
    <view class="form-group">
      <view class="form-label">联系电话</view>
      <input 
        class="form-input" 
        placeholder="请输入联系电话" 
        value="{{form.receiver_phone}}"
        data-field="receiver_phone"
        bindinput="onInput"
        type="number"
      />
    </view>
    
    <view class="form-group">
      <view class="form-label">收货地址</view>
      <view class="location-picker" bindtap="chooseLocation">
        <text class="location-text">{{form.address || '点击选择收货地址'}}</text>
        <text class="location-icon">📍</text>
      </view>
    </view>
    
    <view class="form-group default-switch">
      <view class="form-label">设为默认地址</view>
      <view 
        class="switch-btn {{form.is_default ? 'active' : ''}}" 
        bindtap="toggleDefault"
      >
        <view wx:if="{{form.is_default}}" class="switch-dot"></view>
      </view>
    </view>
    
    <view class="save-btn" bindtap="saveAddress">
      保存地址
    </view>
  </view>
</view>
